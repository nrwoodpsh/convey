# ── 인증(JWT) ────────────────────────────────────────────
JWT_SECRET=change-me-access-secret-please-rotate
JWT_ALGORITHM=HS256
ACCESS_TTL_SECONDS=7200
REFRESH_TTL_SECONDS=86400

# ── 게이트웨이↔서비스 신뢰(HMAC) ──────────────────────────
# 게이트웨이가 하류 호출에 서명, 서비스가 검증. JWT_SECRET과 반드시 분리.
GATEWAY_INTERNAL_SECRET=change-me-internal-hmac-secret

# ── Postgres ─────────────────────────────────────────────
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── Kafka ────────────────────────────────────────────────
KAFKA_BOOTSTRAP=kafka:9092

# ── Ollama (LLM 서빙) ─────────────────────────────────────
# 컨테이너 ollama 사용: http://ollama:11434
# 호스트(네이티브) ollama 재사용: http://host.docker.internal:11434 (이 경우 ollama 컨테이너 미기동)
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llama3.2

# ── 호스트 포트(충돌 시 변경) ─────────────────────────────
GATEWAY_PORT=8080
POSTGRES_HOST_PORT=5432
KAFKAUI_PORT=8090
OLLAMA_PORT=11434

# ── 공통 ─────────────────────────────────────────────────
LOG_LEVEL=INFO
ENV=local
