# ── 인증(Supabase Auth — ADR 0007) ───────────────────────
# 로그인·토큰 발급은 Supabase. 게이트웨이는 JWKS로 검증만 한다. 프로젝트 생성 후 채움.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_JWKS_URL=
SUPABASE_AUD=authenticated

# ── 게이트웨이↔서비스 신뢰(HMAC) ──────────────────────────
# 게이트웨이가 하류 호출에 서명, 서비스가 검증. 인증 토큰과 별개 시크릿.
GATEWAY_INTERNAL_SECRET=change-me-internal-hmac-secret

# ── Postgres ─────────────────────────────────────────────
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── Kafka ────────────────────────────────────────────────
KAFKA_BOOTSTRAP=kafka:9092
KAFKA_HOST_PORT=29092   # 호스트 외부 리스너(로컬 검증·툴). 내부는 kafka:9092

# ── Neo4j (지식 그래프 — 관계·인과, ADR 0005) ─────────────
NEO4J_AUTH=neo4j/convey-dev-pw
NEO4J_URL=bolt://neo4j:7687
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

# ── Ollama (LLM 서빙) ─────────────────────────────────────
# 컨테이너 ollama 사용: http://ollama:11434
# 호스트(네이티브) ollama 재사용: http://host.docker.internal:11434 (이 경우 ollama 컨테이너 미기동)
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llama3.2

# ── 외부 연동 (실연동 시 채움 · 값 커밋 금지) — 발급·확인: doc/ref/external-credentials.md ──
# 뉴스 RSS (키 없음 — 공개 피드 CSV). 비우면 config 기본(연합뉴스·한경) 사용
FEED_URLS=https://www.yna.co.kr/rss/economy.xml,https://www.hankyung.com/feed/economy
# 공시 DART (무료 키 — opendart.fss.or.kr). 없으면 공시 스킵
DART_API_KEY=
# KIS OpenAPI (시세)
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT=
KIS_BASE_URL=https://openapi.koreainvestment.com:9443
# 이미지 생성 (broll · 커모디티)
IMAGE_GEN_BASE_URL=
IMAGE_GEN_API_KEY=
# TTS (음성 · 커모디티)
TTS_BASE_URL=
TTS_API_KEY=
# YouTube Data API v3 (발행 — 사람 승인 후에만)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# ── 호스트 포트(충돌 시 변경) ─────────────────────────────
GATEWAY_PORT=8080
POSTGRES_HOST_PORT=5432
KAFKAUI_PORT=8090
OLLAMA_PORT=11434

# ── 공통 ─────────────────────────────────────────────────
LOG_LEVEL=INFO
ENV=local
