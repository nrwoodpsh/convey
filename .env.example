# ── 인증(Supabase Auth — ADR 0007) ───────────────────────
# 로그인·토큰 발급은 Supabase. 게이트웨이는 JWKS로 검증만 한다. 프로젝트 생성 후 채움.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_JWKS_URL=
SUPABASE_AUD=authenticated

# ── 게이트웨이↔서비스 신뢰(HMAC) ──────────────────────────
# 게이트웨이가 하류 호출에 서명, 서비스가 검증. 인증 토큰과 별개 시크릿.
GATEWAY_INTERNAL_SECRET=change-me-internal-hmac-secret

# ── Postgres ─────────────────────────────────────────────
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── Kafka ────────────────────────────────────────────────
KAFKA_BOOTSTRAP=kafka:9092

# ── Neo4j (지식 그래프 — 관계·인과, ADR 0005) ─────────────
NEO4J_AUTH=neo4j/convey-dev-pw
NEO4J_URL=bolt://neo4j:7687
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

# ── Ollama (LLM 서빙) ─────────────────────────────────────
# 컨테이너 ollama 사용: http://ollama:11434
# 호스트(네이티브) ollama 재사용: http://host.docker.internal:11434 (이 경우 ollama 컨테이너 미기동)
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llama3.2

# ── 호스트 포트(충돌 시 변경) ─────────────────────────────
GATEWAY_PORT=8080
POSTGRES_HOST_PORT=5432
KAFKAUI_PORT=8090
OLLAMA_PORT=11434

# ── 공통 ─────────────────────────────────────────────────
LOG_LEVEL=INFO
ENV=local
